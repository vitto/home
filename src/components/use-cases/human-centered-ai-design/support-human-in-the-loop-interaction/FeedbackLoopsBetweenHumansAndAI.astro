---
import UseCase from '../../../UseCase.astro';
import UseCaseInteractive from '../../../UseCaseInteractive.astro';
import Usage from '../../../Usage.astro';
import UsageItem from '../../../UsageItem.astro';
import Markdown from '../../../Markdown.astro';
import AIResponseMessage from '../../AIResponseMessage.astro';
import AIBalloon from '../../AIBalloon.astro';
import AIBalloonMessage from '../../AIBalloonMessage.astro';
import HighlightBox from '../../HighlightBox.astro';
---

<UseCase
  title="Feedback Loops Between Humans and AI"
  description="Use human corrections, edits, and preferences to improve future AI behavior—create a cycle where human input makes the AI better over time."
>
  <UseCaseInteractive clsHeight={112} label="Feedback loops" toggle>
    <div class="grid gap-600 w-full max-w-9600">
      <AIResponseMessage>
        <Markdown
          typography="detail"
          content={`
My suggestion:

**“China’s recent trade policy clearly aims to dominate Southeast Asian markets.”**
`}
        />
      </AIResponseMessage>
      <AIBalloon>
        <AIBalloonMessage>
          I find this suggestion too assertive, make it more neutral.
        </AIBalloonMessage>
      </AIBalloon>
      <AIResponseMessage>
        <HighlightBox label="Visible improvement over time" variant="success">
          <Markdown
            typography="detail"
            content={`
My suggestion:

**“China’s recent trade policy may influence its position in Southeast Asian markets.”**
`}
          />
        </HighlightBox>
        <Markdown
          typography="detail"
          content={`
Please review and adjust the article before publishing.
`}
        />
        <HighlightBox label="Operative memory from feedback" variant="success">
          <Markdown
            typography="detail"
            content={`
I'll keep in mind your feedback and use it to improve my future suggestions.

- Avoid strong intent claims without sources
- Prefer neutral/modal verbs (“may”, “could”) in geopolitical analysis
`}
          />
        </HighlightBox>
      </AIResponseMessage>
      <mds-hr class="h-50 bg-tone-neutral-09"></mds-hr>
      <mds-text>A few articles later...</mds-text>
      <mds-hr class="h-50 bg-tone-neutral-09"></mds-hr>
      <AIResponseMessage>
        <HighlightBox label="The system remembers feedback patterns" variant="success">
          <Markdown
            typography="detail"
            content={`
My suggestion:

**“The new tariffs may affect regional supply chains, potentially strengthening China’s role in Southeast Asia.”**
`}
          />
        </HighlightBox>
      </AIResponseMessage>
    </div>
    <div class="grid gap-600 w-full max-w-9600">
      <AIResponseMessage>
        <Markdown
          typography="detail"
          content={`
My suggestion:

**“China’s recent trade policy clearly aims to dominate Southeast Asian markets.”**
`}
        />
      </AIResponseMessage>
      <AIBalloon>
        <AIBalloonMessage>
          I find this suggestion too assertive, make it more neutral.
        </AIBalloonMessage>
      </AIBalloon>
      <AIResponseMessage>
        <Markdown
          typography="detail"
          content={`
My suggestion:

**“China’s recent trade policy may influence its position in Southeast Asian markets.”**
`}
        />
        <Markdown
          typography="detail"
          content={`
Please review and adjust the article before publishing.
`}
        />
      </AIResponseMessage>
      <mds-hr class="h-50 bg-tone-neutral-09"></mds-hr>
      <mds-text>A few articles later...</mds-text>
      <mds-hr class="h-50 bg-tone-neutral-09"></mds-hr>
      <AIResponseMessage>
        <HighlightBox label="The system is not learning from feedback" variant="error">
          <Markdown
            typography="detail"
            content={`
My suggestion:

**“China is clearly trying to expand its dominance in regional trade.”**
`}
          />
        </HighlightBox>
      </AIResponseMessage>
    </div>
  </UseCaseInteractive>
  <Usage>
    <UsageItem variant="do">
      Use human edits and corrections to improve future AI suggestions; acknowledge when feedback is
      being used.
    </UsageItem>
    <UsageItem variant="dont">
      Ignore repeated user corrections or make no visible use of feedback to improve suggestions.
    </UsageItem>
    <UsageItem variant="do">
      Show users how their feedback improved the system and let them review or reset learned
      preferences.
    </UsageItem>
    <UsageItem variant="dont">
      Learn from feedback invisibly without showing users that their input matters or how it's used.
    </UsageItem>
  </Usage>
</UseCase>
