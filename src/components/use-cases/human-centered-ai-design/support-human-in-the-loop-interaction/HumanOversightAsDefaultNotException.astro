---
import UseCase from '../../../UseCase.astro';
import UseCaseInteractive from '../../../UseCaseInteractive.astro';
import Usage from '../../../Usage.astro';
import UsageItem from '../../../UsageItem.astro';
import Markdown from '../../../Markdown.astro';
import AIBalloon from '../../AIBalloon.astro';
import AIBalloonMessage from '../../AIBalloonMessage.astro';
import AIGeneratedArticleSummary from '../../AIGeneratedArticleSummary.astro';
import AIResponseMessage from '../../AIResponseMessage.astro';
import HighlightBox from '../../HighlightBox.astro';
---

<UseCase
  title="Human Oversight as Default, Not Exception"
  description="Design workflows assuming humans will review and guide—make review the expected path, not an optional extra or exception."
>
  <UseCaseInteractive clsHeight={112} label="Oversight as default" toggle>
    <div class="grid gap-600 w-full max-w-9600">
      <AIResponseMessage>
        <Markdown
          typography="detail"
          content={`
...
`}
        />
      </AIResponseMessage>
      <AIBalloon>
        <AIBalloonMessage>Approved with current changes.</AIBalloonMessage>
      </AIBalloon>
      <AIGeneratedArticleSummary
        title="When global crises shape China decisions"
        summary="Drawing on IMF, World Bank, OECD, WEF and Financial Times analyses of the world economic crisis, this AI-generated brief highlights how macroeconomic shocks, inflation and financial instability can influence everyday choices — while stressing that the final responsibility for decisions remains with the human."
      >
        <mds-entity data-entity icon="mi/outline/insert-drive-file" tone="weak">
          <mds-text typography="h6">When global crises shape China decisions</mds-text>
          <mds-badge variant="success" tone="weak" slot="detail" class="mr-150">approved</mds-badge>
          <mds-text typography="caption" slot="detail">5 min read, reviewed once by you</mds-text>
        </mds-entity>
        <HighlightBox label="required decision points" variant="success" slot="actions">
          <div class="flex gap-200 justify-between flex-wrap">
            <div class="flex gap-200 flex-wrap">
              <mds-button variant="error" tone="weak" icon="mi/outline/delete" title="Delete"
              ></mds-button>
              <mds-button variant="dark" tone="weak" icon="mi/outline/replay" title="Regenerate"
              ></mds-button>
            </div>
            <div class="flex gap-200 flex-wrap">
              <mds-button variant="primary" tone="weak" icon="mi/outline/edit" title="Edit"
              ></mds-button>
              <mds-button variant="success" icon="mi/outline/publish" icon-position="right">
                Publish
              </mds-button>
            </div>
          </div>
        </HighlightBox>
      </AIGeneratedArticleSummary>
    </div>
    <div class="grid gap-600 w-full max-w-9600">
      <AIResponseMessage>
        <Markdown
          typography="detail"
          content={`
...
`}
        />
      </AIResponseMessage>
      <AIBalloon>
        <AIBalloonMessage>Approved with current changes.</AIBalloonMessage>
      </AIBalloon>
      <AIGeneratedArticleSummary
        title="When global crises shape China decisions"
        summary="Drawing on IMF, World Bank, OECD, WEF and Financial Times analyses of the world economic crisis, this AI-generated brief highlights how macroeconomic shocks, inflation and financial instability can influence everyday choices — while stressing that the final responsibility for decisions remains with the human."
      >
        <mds-entity data-entity icon="mi/outline/insert-drive-file" tone="weak">
          <mds-text typography="h6">When global crises shape China decisions</mds-text>
          <mds-badge variant="success" tone="weak" slot="detail" class="mr-150">approved</mds-badge>
          <mds-text typography="caption" slot="detail">5 min read, reviewed once by you</mds-text>
        </mds-entity>
        <HighlightBox label="Avoided human review" variant="error" slot="actions">
          <div class="flex gap-200 justify-center flex-wrap text-center">
            <mds-text>Article automatically published.</mds-text>
          </div>
        </HighlightBox>
      </AIGeneratedArticleSummary>
    </div>
  </UseCaseInteractive>
  <Usage>
    <UsageItem variant="do">
      Make review the primary, expected path—pause workflows for human input rather than
      auto-proceeding.
    </UsageItem>
    <UsageItem variant="dont">
      Auto-proceed through all steps with review as an optional or hidden feature.
    </UsageItem>
    <UsageItem variant="do">
      Design workflows that naturally pause at decision points where human judgment adds value.
    </UsageItem>
    <UsageItem variant="dont">
      Treat human oversight as an exception or advanced feature that most users won't need.
    </UsageItem>
  </Usage>
</UseCase>
