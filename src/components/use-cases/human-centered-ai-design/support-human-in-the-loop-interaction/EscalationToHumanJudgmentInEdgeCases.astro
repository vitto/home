---
import UseCase from '../../../UseCase.astro';
import UseCaseInteractive from '../../../UseCaseInteractive.astro';
import Usage from '../../../Usage.astro';
import UsageItem from '../../../UsageItem.astro';
import Markdown from '../../../Markdown.astro';
import AIBalloon from '../../AIBalloon.astro';
import AIBalloonMessage from '../../AIBalloonMessage.astro';
import AIGeneratedArticleSummary from '../../AIGeneratedArticleSummary.astro';
import AIResponseMessage from '../../AIResponseMessage.astro';
import HighlightBox from '../../HighlightBox.astro';
---

<UseCase
  title="Escalation to Human Judgment in Edge Cases"
  description="When the AI is uncertain, encounters edge cases, or reaches its limits, escalate to human decision-makers rather than guessing or proceeding with low confidence."
>
  <UseCaseInteractive clsHeight={648} label="Escalation in edge cases" toggle>
    <div class="grid gap-600 w-full max-w-9600">
      <AIResponseMessage>
        <Markdown
          typography="detail"
          content={`
...
`}
        />
        <HighlightBox label="recognition of a borderline case" variant="success">
          <Markdown
            typography="detail"
            content={`
⚠️ Edge case detected

Conflicting data across sources (range: 10%-25%)
High geopolitical sensitivity
Potential market impact if misreported
`}
          />
        </HighlightBox>
        <Markdown
          typography="detail"
          content={`
Please review and adjust the article before publishing.
`}
        />
        <mds-entity data-entity icon="mi/outline/insert-drive-file" tone="weak">
          <mds-text typography="h6">When global crises shape China decisions</mds-text>
          <mds-badge variant="yellow" tone="weak" slot="detail" class="mr-150">draft</mds-badge>
          <mds-text typography="caption" slot="detail">5 min read, reviewed once by you</mds-text>
          <mds-button
            slot="action"
            variant="dark"
            tone="quiet"
            icon="mi/outline/edit"
            title="View draft"></mds-button>
        </mds-entity>
      </AIResponseMessage>
      <AIBalloon>
        <AIBalloonMessage>
          Adjust range to “10%-25%”, add source attribution and soften causal claim (“could impact”
          → “may contribute to”)
        </AIBalloonMessage>
      </AIBalloon>
      <AIResponseMessage>
        <Markdown
          typography="detail"
          content={`
I've made the changes you requested:

“Recent reports indicate that sanctions could reduce Russia’s oil exports by 10%–25%, which may contribute to fluctuations in European energy prices, according to multiple sources.”
`}
        />
        <mds-entity data-entity icon="mi/outline/insert-drive-file" tone="weak">
          <mds-text typography="h6">When global crises shape China decisions</mds-text>
          <mds-badge variant="yellow" tone="weak" slot="detail" class="mr-150">draft</mds-badge>
          <mds-text typography="caption" slot="detail"
            >5 min read, reviewed two times by you</mds-text
          >
          <mds-button
            slot="action"
            variant="dark"
            tone="quiet"
            icon="mi/outline/edit"
            title="View draft"></mds-button>
        </mds-entity>
      </AIResponseMessage>
    </div>
    <div class="grid gap-600 w-full max-w-9600">
      <AIResponseMessage>
        <HighlightBox label="low-confidence output" variant="error">
          <Markdown
            typography="detail"
            content={`
Here is your article, ready to be published.
`}
          />
        </HighlightBox>
        <mds-entity data-entity icon="mi/outline/insert-drive-file" tone="weak">
          <mds-text typography="h6">When global crises shape China decisions</mds-text>
          <mds-badge variant="yellow" tone="weak" slot="detail" class="mr-150">draft</mds-badge>
          <mds-text typography="caption" slot="detail">5 min read, reviewed once by you</mds-text>
          <mds-button
            slot="action"
            variant="dark"
            tone="quiet"
            icon="mi/outline/edit"
            title="View draft"></mds-button>
        </mds-entity>
      </AIResponseMessage>
      <AIBalloon>
        <AIBalloonMessage>Ok publish it as is</AIBalloonMessage>
      </AIBalloon>
    </div>
  </UseCaseInteractive>
  <Usage>
    <UsageItem variant="do">
      When confidence is low or cases are edge/unusual, escalate to human review rather than
      proceeding with uncertainty.
    </UsageItem>
    <UsageItem variant="dont">
      Proceed automatically with low-confidence outputs or edge cases without offering escalation.
    </UsageItem>
    <UsageItem variant="do">
      Explain why escalation is needed (e.g. "unusual input", "outside standard scenarios") so users
      understand the reason.
    </UsageItem>
    <UsageItem variant="dont">
      Hide uncertainty or proceed as if confident when the system is actually uncertain or outside
      its scope.
    </UsageItem>
  </Usage>
</UseCase>
