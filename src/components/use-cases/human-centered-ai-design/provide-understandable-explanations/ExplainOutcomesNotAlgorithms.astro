---
import UseCase from '../../../UseCase.astro';
import UseCaseInteractive from '../../../UseCaseInteractive.astro';
import Usage from '../../../Usage.astro';
import UsageItem from '../../../UsageItem.astro';
import Markdown from '../../../Markdown.astro';
import AIBalloon from '../../AIBalloon.astro';
import AIBalloonMessage from '../../AIBalloonMessage.astro';
import AIResponseMessage from '../../AIResponseMessage.astro';
import HighlightBox from '../../HighlightBox.astro';
import headphonesData from '../../../../data/use-cases/headphones.json';
import AILink from '../../AILink.astro';
import AILinks from '../../AILinks.astro';
---

<UseCase
  title="Explain Outcomes, Not Algorithms"
  description="Focus explanations on what the AI did and why it matters to the user, not on technical details about how the model works."
>
  <UseCaseInteractive clsHeight={112} label="Outcome-focused explanations" toggle>
    <div class="grid gap-600 w-full max-w-9600">
      <AIBalloon>
        <AIBalloonMessage>Can you recommend a good pair of headphones for music?</AIBalloonMessage>
      </AIBalloon>
      <AIResponseMessage>
        <HighlightBox label="Focus on outcomes" variant="success">
          <Markdown
            typography="detail"
            content={`
I recommend the **Sony WH-1000XM5** because they offer a well-balanced sound profile, which works well across different music genres. They are also very comfortable for long listening sessions and have excellent noise cancellation, which helps you focus on the music even in noisy environments.

If you mainly listen at home or prefer stronger bass, there might be better alternatives—let me know your preferences.
        `}
          />
        </HighlightBox>
        <AILinks>
          {
            headphonesData.map(
              (headphone: { model: string; title: string; description: string; image: string }) => (
                <AILink
                  href="https://vittoriovittori.com"
                  picture={headphone.image}
                  title={headphone.title}
                  description={headphone.description}
                />
              )
            )
          }
        </AILinks>
      </AIResponseMessage>
    </div>
    <div class="grid gap-600 w-full max-w-9600">
      <AIBalloon>
        <AIBalloonMessage>Can you recommend a good pair of headphones for music?</AIBalloonMessage>
      </AIBalloon>
      <AIResponseMessage>
        <HighlightBox label="Focus on algorithms" variant="error">
          <Markdown
            typography="detail"
            content={`
I recommend the **Sony WH-1000XM5** because our model analyzed large datasets of user reviews and product specifications, then ranked this option highest based on weighted scoring of audio quality, comfort, and noise cancellation.
        `}
          />
        </HighlightBox>
        <AILinks>
          {
            headphonesData.map(
              (headphone: { model: string; title: string; description: string; image: string }) => (
                <AILink
                  href="https://vittoriovittori.com"
                  picture={headphone.image}
                  title={headphone.title}
                  description={headphone.description}
                />
              )
            )
          }
        </AILinks>
      </AIResponseMessage>
    </div>
  </UseCaseInteractive>
  <Usage>
    <UsageItem variant="do">
      Explain what the AI output means for the user's situation or decision.
    </UsageItem>
    <UsageItem variant="dont">
      Describe model architecture, training methods, or technical implementation details.
    </UsageItem>
    <UsageItem variant="do">
      Focus on factors that influenced the output and why they matter.
    </UsageItem>
    <UsageItem variant="dont">
      Use technical jargon that requires AI/ML expertise to understand.
    </UsageItem>
  </Usage>
</UseCase>
