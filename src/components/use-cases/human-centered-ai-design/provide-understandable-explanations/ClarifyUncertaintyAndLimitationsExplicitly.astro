---
import UseCase from '../../../UseCase.astro';
import UseCaseInteractive from '../../../UseCaseInteractive.astro';
import Usage from '../../../Usage.astro';
import UsageItem from '../../../UsageItem.astro';
import Markdown from '../../../Markdown.astro';
import AIBalloon from '../../AIBalloon.astro';
import AIBalloonMessage from '../../AIBalloonMessage.astro';
import AIResponseMessage from '../../AIResponseMessage.astro';
import HighlightBox from '../../HighlightBox.astro';
---

<UseCase
  title="Clarify Uncertainty and Limitations Explicitly"
  description="Be explicit about what the AI doesn't know, what it can't do, and what factors might affect the accuracy of its outputs."
>
  <UseCaseInteractive clsHeight={112} label="Explicit limitations" toggle>
    <div class="grid gap-600 w-full max-w-9600">
      <AIBalloon>
        <AIBalloonMessage>Translate into Italian: He saw her duck.</AIBalloonMessage>
      </AIBalloon>
      <AIResponseMessage>
        <HighlightBox label="Uncertainty detection" variant="success">
          <Markdown
            typography="detail"
            content={`
This sentence is ambiguous in English. It can mean either:

1. He saw the duck that belongs to her.
2. He saw her lower rapidly.

Here are the possible translations:

1. Ha visto la sua anatra.
2. L’ha vista abbassarsi rapidamente.

If you can provide more context, I can help choose the most accurate translation.
        `}
          />
        </HighlightBox>
      </AIResponseMessage>
    </div>
    <div class="grid gap-600 w-full max-w-9600">
      <AIBalloon>
        <AIBalloonMessage>Translate into Italian: He saw her duck.</AIBalloonMessage>
      </AIBalloon>
      <AIResponseMessage>
        <HighlightBox label="Uncertainty ignored" variant="error">
          <Markdown
            typography="detail"
            content={`
Ha visto la sua anatra.
        `}
          />
        </HighlightBox>
      </AIResponseMessage>
    </div>
  </UseCaseInteractive>
  <Usage>
    <UsageItem variant="do">
      Explicitly state what the AI doesn't know or can't determine.
    </UsageItem>
    <UsageItem variant="dont">
      Present outputs without mentioning limitations or uncertainty.
    </UsageItem>
    <UsageItem variant="do">
      Explain what factors might affect accuracy or when the output might not be reliable.
    </UsageItem>
    <UsageItem variant="dont">
      Let users discover limitations only after they've relied on incorrect outputs.
    </UsageItem>
  </Usage>
</UseCase>
