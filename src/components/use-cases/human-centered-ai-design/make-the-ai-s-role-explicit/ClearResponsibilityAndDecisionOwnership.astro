---
import UseCase from '../../../UseCase.astro';
import UseCaseInteractive from '../../../UseCaseInteractive.astro';
import Usage from '../../../Usage.astro';
import UsageItem from '../../../UsageItem.astro';
import Brand from '../../../Brand.astro';
import ProductCategory from '../../../ProductCategory.astro';
import Products from '../../../Products.astro';
---

<UseCase
  title="Clear Responsibility and Decision Ownership"
  description="Users should know who is responsible for decisions: the AI makes suggestions, but the user retains final control."
>
  <UseCaseInteractive clsHeight={348} label="Decision ownership" toggle>
    <div class="grid gap-600 w-full max-w-9600">
      <mds-banner
        icon="mgg/ai-chatbot-outline"
        headline="AI schedule suggestion"
        variant="ai"
        tone="weak"
      >
        <mds-text typography="caption"
          >Based on your preferences, the system would recommend you to schedule the meeting for
          Tuesday at 2 PM.</mds-text
        >
        <mds-hr class="h-50 my-400"></mds-hr>
        <mds-input-switch size="sm" explicit>
          <mds-text typography="caption"
            >Automatically send a follow-up email in 24 hours if no response is received.</mds-text
          >
        </mds-input-switch>
        <mds-hr class="h-50 mt-400 mb-200"></mds-hr>
        <mds-button slot="action" variant="ai" tone="weak">Change time</mds-button>
        <mds-button slot="action" variant="ai">Confirm</mds-button>
      </mds-banner>
    </div>
    <div class="grid gap-600 w-full max-w-9600">
      <mds-banner
        icon="mgg/ai-chatbot-outline"
        headline="AI schedule suggestion"
        variant="ai"
        tone="weak"
      >
        <mds-text typography="caption"
          >Based on your preferences, the system would recommend you to schedule the meeting for
          Tuesday at 2 PM. The system will send a follow-up email in 24 hours if no response is
          received.</mds-text
        >
        <mds-button slot="action" variant="ai" tone="weak">Preferences</mds-button>
        <mds-button slot="action" variant="ai" tone="weak">Change time</mds-button>
        <mds-button slot="action" variant="ai">Confirm</mds-button>
      </mds-banner>
    </div>
  </UseCaseInteractive>
  <Usage>
    <UsageItem variant="do">
      Clearly distinguish between AI suggestions and automated actions.
    </UsageItem>
    <UsageItem variant="dont">
      Let the AI make irreversible decisions without explicit user consent.
    </UsageItem>
    <UsageItem variant="do">Provide clear opt-out mechanisms for automated behaviors.</UsageItem>
    <UsageItem variant="dont">Hide or obscure who is responsible for outcomes.</UsageItem>
  </Usage>

  <Products>
    <ProductCategory title="Decision support systems">
      <Brand name="notion" label="Notion AI" url="https://notion.so/product/ai" />
      <Brand name="github" label="GitHub Copilot" url="https://github.com/features/copilot" />
    </ProductCategory>
  </Products>
</UseCase>
