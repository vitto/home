---
import UseCase from '../../../UseCase.astro';
import UseCaseInteractive from '../../../UseCaseInteractive.astro';
import Usage from '../../../Usage.astro';
import UsageItem from '../../../UsageItem.astro';
import AIBalloon from '../../AIBalloon.astro';
import AIBalloonMessage from '../../AIBalloonMessage.astro';
import HighlightBox from '../../HighlightBox.astro';
---

<UseCase
  title="Explicit AI Presence and Identity"
  description="Users should immediately recognize when they're interacting with an AI system, not a human agent."
>
  <UseCaseInteractive clsHeight={112} label="AI identity indicators" toggle>
    <div class="grid gap-600 w-full max-w-9600">
      <mds-emoji class="size-2400 m-auto" data-ai-chatbot></mds-emoji>
      <HighlightBox label="Clear AI presence" variant="success">
        <mds-text typography="caption"
          >Hello, I'm Hexago, the <b>AI assistant</b> of Beauty Center I Rituali di Fiore. I can help
          you make an appointment for a treatment. How can I help you?</mds-text
        >
      </HighlightBox>
      <AIBalloon>
        <AIBalloonMessage>
          I'd like to make an appointment for a facial massage. What dates are available?
        </AIBalloonMessage>
      </AIBalloon>
    </div>
    <div class="grid gap-600 w-full max-w-9600">
      <video
        class="size-2400 m-auto rounded-xl object-cover object-top"
        autoplay
        loop
        muted
        src="/assets/ai-antropomorphic-assistant.mp4"></video>
      <HighlightBox label="Unclear AI presence" variant="error">
        <mds-text typography="caption"
          >Hello, I'm Vera, the assistant of Beauty Center I Rituali di Fiore. I can help you make
          an appointment for a treatment. How can I help you?</mds-text
        >
      </HighlightBox>
      <AIBalloon>
        <AIBalloonMessage>
          Hello Vera, nice to meet you. Are you available for a facial massage tomorrow?
        </AIBalloonMessage>
      </AIBalloon>
    </div>
  </UseCaseInteractive>
  <script>
    function initAiChatbotBlinking() {
      const emojiEl = document.querySelector('[data-ai-chatbot]');
      if (!emojiEl) return;

      const api = emojiEl as unknown as {
        startBlinking?: () => void;
        startFollowMouse?: () => void;
        stopFollowMouse?: () => void;
      };

      const runBlinking = () => {
        if (typeof api.startBlinking === 'function') api.startBlinking.call(emojiEl);
      };

      const runFollowMouse = () => {
        if (typeof api.startFollowMouse === 'function') api.startFollowMouse.call(emojiEl);
      };

      const runStopFollowMouse = () => {
        if (typeof api.stopFollowMouse === 'function') api.stopFollowMouse.call(emojiEl);
      };

      if (customElements.get('mds-emoji')) {
        runBlinking();
      } else {
        customElements.whenDefined('mds-emoji').then(runBlinking);
      }

      const interactiveContainer = emojiEl.closest('.use-case-interactive-content')?.parentElement;
      if (interactiveContainer) {
        interactiveContainer.addEventListener('mouseenter', runFollowMouse);
        interactiveContainer.addEventListener('mouseleave', runStopFollowMouse);
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initAiChatbotBlinking);
    } else {
      initAiChatbotBlinking();
    }
  </script>
  <Usage>
    <UsageItem variant="do">
      Use clear visual indicators (icons, badges) to distinguish AI from human agents.
    </UsageItem>
    <UsageItem variant="dont">
      Hide or obscure the AI's identity to make it seem more human.
    </UsageItem>
    <UsageItem variant="do">State the AI's identity in the first interaction.</UsageItem>
    <UsageItem variant="dont">
      Use ambiguous language that could apply to either AI or humans.
    </UsageItem>
  </Usage>
</UseCase>
