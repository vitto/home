---
import UseCase from '../../../UseCase.astro';
import UseCaseInteractive from '../../../UseCaseInteractive.astro';
import Usage from '../../../Usage.astro';
import UsageItem from '../../../UsageItem.astro';
import Markdown from '../../../Markdown.astro';
import AIBalloon from '../../AIBalloon.astro';
import AIBalloonMessage from '../../AIBalloonMessage.astro';
import AIResponseMessage from '../../AIResponseMessage.astro';
import HighlightBox from '../../HighlightBox.astro';
---

<UseCase
  title="Reducing Decision Fatigue"
  description="Offer sensible defaults and fewer, clearer choices so users aren't worn down by too many micro-decisions or unclear options."
>
  <UseCaseInteractive clsHeight={312} label="Reducing decision fatigue" toggle>
    <div class="grid gap-600 w-full max-w-9600">
      <AIBalloon>
        <AIBalloonMessage>
          I received an order with two products, one of which is defective. How do I get a refund?
        </AIBalloonMessage>
      </AIBalloon>
      <AIResponseMessage>
        <HighlightBox label="few and clear decisions" variant="success">
          <Markdown
            typography="detail"
            content={`
You can refund just the defective item.

Choose one option:

- Refund to original payment method (5-7 days)
- Instant store credit (available immediately)

Most people choose instant store credit for faster access.
        `}
          />
        </HighlightBox>
      </AIResponseMessage>
    </div>
    <div class="grid gap-600 w-full max-w-9600">
      <AIBalloon>
        <AIBalloonMessage>
          I received an order with two products, one of which is defective. How do I get a refund?
        </AIBalloonMessage>
      </AIBalloon>
      <AIResponseMessage>
        <HighlightBox label="Too many options" variant="error">
          <Markdown
            typography="detail"
            content={`
You can request a refund for the defective item. Please choose how you would like to proceed:

- Refund to original payment method (credit card, debit card, PayPal, or other)
- Store credit
- Replacement product (if available)
- Exchange for a different item
- Partial refund with discount retention (if applicable)

Each option may have different processing times depending on the payment provider, product category, and seller policies. Please review all terms and conditions before selecting.
        `}
          />
        </HighlightBox>
      </AIResponseMessage>
    </div>
  </UseCaseInteractive>
  <Usage>
    <UsageItem variant="do">
      Provide a single recommended path or default; let users override when they need to.
    </UsageItem>
    <UsageItem variant="dont">
      Require many small decisions before the user can proceed, with no sensible default.
    </UsageItem>
    <UsageItem variant="do">
      Keep choice sets small (e.g. 2-4 options) and label them so outcomes are clear.
    </UsageItem>
    <UsageItem variant="dont">
      Present long lists of similar options or technical settings without guidance.
    </UsageItem>
  </Usage>
</UseCase>
