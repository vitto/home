---
import UseCase from '../../../UseCase.astro';
import UseCaseInteractive from '../../../UseCaseInteractive.astro';
import Usage from '../../../Usage.astro';
import UsageItem from '../../../UsageItem.astro';
import OptionCheckbox from '../../OptionCheckbox.astro';
---

<UseCase
  title="Adjustable Autonomy Levels"
  description="Allow users to configure how much autonomy the AI has, from fully manual control to various levels of automation."
>
  <UseCaseInteractive clsHeight={112} label="Autonomy configuration" toggle>
    <div class="grid gap-600 w-full max-w-9600">
      <div class="grid gap-100 grid-cols-full">
        <mds-text typography="h6">Autonomy Settings</mds-text>
        <mds-text typography="caption"
          >Choose the autonomy level that matches your comfort and workflow needs.</mds-text
        >
      </div>
      <div class="grid gap-200 grid-cols-full" data-autonomy-settings>
        <OptionCheckbox
          label="Manual"
          description="AI only suggests, I decide everything"
          selected
          name="autonomy-level"
        />
        <OptionCheckbox
          label="Assisted"
          description="AI acts only after I approve"
          name="autonomy-level"
        />
        <OptionCheckbox
          label="Semi-Automated (low risk)"
          description="AI acts automatically for safe tasks"
          name="autonomy-level"
        />
        <OptionCheckbox
          label="Fully Automated (high risk)"
          description="AI acts automatically for all tasks"
          name="autonomy-level"
        />
      </div>
    </div>
    <div class="grid gap-100 w-full max-w-9600">
      <mds-text typography="h6">Autonomy Settings</mds-text>
      <mds-text typography="caption"
        >The AI automatically performs all actions. No settings available to change this behavior.</mds-text
      >
    </div>
  </UseCaseInteractive>
  <Usage>
    <UsageItem variant="do">
      Provide settings that allow users to adjust AI autonomy levels.
    </UsageItem>
    <UsageItem variant="dont">Force all users to accept the same level of AI automation.</UsageItem>
    <UsageItem variant="do">
      Allow granular control—different autonomy levels for different features or task types.
    </UsageItem>
    <UsageItem variant="dont">
      Hide autonomy settings or make them difficult to find or understand.
    </UsageItem>
  </Usage>
</UseCase>

<script>
  function initAutonomyRadioGroup() {
    const container = document.querySelector('[data-autonomy-settings]');
    if (!container) return;

    const options = Array.from(
      container.querySelectorAll<HTMLButtonElement>('[data-option-checkbox]')
    );
    if (!options.length) return;

    function selectOption(target: HTMLButtonElement) {
      const groupName = target.getAttribute('data-option-name');
      options.forEach((btn) => {
        if (groupName && btn.getAttribute('data-option-name') !== groupName) return;
        const isSelected = btn === target;
        btn.dataset.selected = isSelected ? 'true' : 'false';
        btn.setAttribute('aria-pressed', isSelected ? 'true' : 'false');
        if (groupName) {
          btn.setAttribute('role', 'radio');
          btn.setAttribute('aria-checked', isSelected ? 'true' : 'false');
        }
        btn.classList.toggle('bg-tone-neutral', isSelected);
        btn.classList.toggle('shadow-outline-50', isSelected);
        btn.classList.toggle('fill-tone-neutral-04', isSelected);
        btn.classList.toggle('bg-transparent', !isSelected);
        btn.classList.toggle('hover:bg-tone-neutral-09', !isSelected);
        btn.classList.toggle('fill-tone-neutral-06', !isSelected);
        const icon = btn.querySelector('mds-icon');
        if (icon) {
          icon.setAttribute('name', isSelected ? 'mi/baseline/check-circle' : 'mi/outline/circle');
        }
      });
    }

    options.forEach((btn) => {
      btn.addEventListener('click', () => selectOption(btn));
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAutonomyRadioGroup);
  } else {
    initAutonomyRadioGroup();
  }
</script>
