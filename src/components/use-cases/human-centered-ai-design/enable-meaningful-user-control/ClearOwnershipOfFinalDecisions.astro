---
import UseCase from '../../../UseCase.astro';
import UseCaseInteractive from '../../../UseCaseInteractive.astro';
import Usage from '../../../Usage.astro';
import UsageItem from '../../../UsageItem.astro';
import AILink from '../../AILink.astro';
import AILinks from '../../AILinks.astro';
import articleSourcesData from '../../../../data/use-cases/article-sources.json';
---

<UseCase
  title="Clear Ownership of Final Decisions"
  description="Users should understand that they own final decisions, not the AI, especially for important choices."
>
  <UseCaseInteractive clsHeight={112} label="Decision ownership" toggle>
    <div class="grid gap-600 w-full max-w-9600">
      <div class="grid gap-200">
        <mds-text typography="label">Sources</mds-text>
        <AILinks>
          {
            articleSourcesData.map(
              (articleSource: {
                source: string;
                title: string;
                description: string;
                image: string;
              }) => (
                <AILink
                  href="https://vittoriovittori.com"
                  picture={articleSource.image}
                  title={articleSource.title}
                  description={articleSource.description}
                />
              )
            )
          }
        </AILinks>
      </div>
      <div class="grid gap-200">
        <mds-text typography="label">generated article summary</mds-text>
        <div class="grid gap-400 p-600 rounded-lg bg-tone-neutral-10">
          <mds-text typography="h4">When global crises shape local decisions</mds-text>
          <mds-text typography="detail">
            Drawing on IMF, World Bank, OECD, WEF and Financial Times analyses of the world economic
            crisis, this AI-generated brief highlights how macroeconomic shocks, inflation and
            financial instability can influence everyday choices — while stressing that the final
            responsibility for decisions remains with the human.
          </mds-text>
        </div>
        <div class="flex gap-200 justify-between flex-wrap">
          <div class="flex gap-200 flex-wrap">
            <mds-button variant="error" tone="weak" icon="mi/outline/delete" title="Delete"
            ></mds-button>
            <mds-button variant="dark" tone="weak" icon="mi/outline/replay" title="Regenerate"
            ></mds-button>
          </div>
          <div class="flex gap-200 flex-wrap">
            <mds-button variant="primary" tone="weak" icon="mi/outline/edit" title="Edit"
            ></mds-button>
            <mds-button variant="success" icon="mi/outline/publish" icon-position="right"
              >Publish</mds-button
            >
          </div>
        </div>
      </div>
    </div>
    <div class="grid gap-600 w-full max-w-9600">
      <div class="grid gap-200">
        <mds-text typography="label">Sources</mds-text>
        <AILinks>
          {
            articleSourcesData.map(
              (articleSource: {
                source: string;
                title: string;
                description: string;
                image: string;
              }) => (
                <AILink
                  href="https://vittoriovittori.com"
                  picture={articleSource.image}
                  title={articleSource.title}
                  description={articleSource.description}
                />
              )
            )
          }
        </AILinks>
      </div>
      <div class="grid gap-200">
        <mds-text typography="label">generated article summary</mds-text>
        <div class="grid gap-400 p-600 rounded-lg bg-tone-neutral-10">
          <mds-text typography="h4">When global crises shape local decisions</mds-text>
          <mds-text typography="detail">
            Drawing on IMF, World Bank, OECD, WEF and Financial Times analyses of the world economic
            crisis, this AI-generated brief highlights how macroeconomic shocks, inflation and
            financial instability can influence everyday choices — while stressing that the final
            responsibility for decisions remains with the human.
          </mds-text>
        </div>
        <div class="flex gap-200 justify-end flex-wrap">
          <mds-text typography="caption">
            <b>Published:</b> 2026-03-09
          </mds-text>
        </div>
      </div>
    </div>
  </UseCaseInteractive>
  <Usage>
    <UsageItem variant="do">
      Clearly state that users are responsible for final decisions, especially for important
      choices.
    </UsageItem>
    <UsageItem variant="dont">
      Use language that suggests the AI is making decisions or taking responsibility for outcomes.
    </UsageItem>
    <UsageItem variant="do">
      Explain what the AI's role is (support, suggestion, analysis) versus the user's role
      (decision-making).
    </UsageItem>
    <UsageItem variant="dont">
      Blur responsibility boundaries or make it unclear who is accountable for decisions.
    </UsageItem>
  </Usage>
</UseCase>
