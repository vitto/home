---
import UseCase from '../../../UseCase.astro';
import UseCaseInteractive from '../../../UseCaseInteractive.astro';
import Usage from '../../../Usage.astro';
import UsageItem from '../../../UsageItem.astro';
---

<UseCase
  title="Pause, Stop, and Opt-Out Controls"
  description="Users should be able to pause, stop, or completely opt out of AI features at any time."
>
  <UseCaseInteractive label="Stop analyzing book">
    <div class="grid gap-600 w-full">
      <mds-banner headline="Analyzing book" icon="mgg/google-book-large-outline" variant="primary">
        <div class="grid gap-600 grid-cols-full pt-600">
          <mds-benchmark-bar
            class="min-h-[28px] w-full"
            value="0"
            max="100"
            variant="primary"
            data-progress
          >
            <span data-progress-text>Analyzing book</span>
          </mds-benchmark-bar>
          <mds-entity await data-entity icon="mgg/google-book-large-outline" tone="weak">
            <mds-text typography="h6">Haruki Murakami - Dance, Dance, Dance</mds-text>
            <mds-badge variant="amaranth" tone="weak" slot="detail" class="mr-150">epub</mds-badge>
            <mds-text typography="caption" slot="detail">EPUB ebook</mds-text>
          </mds-entity>
        </div>
        <mds-button slot="action" variant="dark" tone="strong" data-cancel-button>Stop</mds-button>
      </mds-banner>
    </div>
  </UseCaseInteractive>
  <script>
    function initBookAnalysisDemo() {
      const scope = (window as any).getUseCaseScope?.('pause-stop-and-opt-out-controls');
      if (!scope) return;

      const { container } = scope;
      const progressBar = container.querySelector('[data-progress]');
      const progressText = container.querySelector('[data-progress-text]');
      const entity = container.querySelector('[data-entity]');
      const cancelBtn = container.querySelector('[data-cancel-button]');
      const contentWrapper = container.querySelector(
        '.use-case-interactive-content'
      )?.firstElementChild;

      if (!progressBar || !progressText || !entity || !cancelBtn) return;

      const TOTAL_CHAPTERS = 44;
      const chapterLabels = Array.from({ length: TOTAL_CHAPTERS }, (_, i) => `Chapter ${i + 1}`);
      const CHAPTER_DELAY_MIN_MS = 10;
      const CHAPTER_DELAY_MAX_MS = 500;
      const STOP_DELAY_MS = 3000;

      let isRunning = false;
      let cancelled = false;
      let chapterIndex = 0;
      let timeoutId: ReturnType<typeof setTimeout> | null = null;
      let isInViewport = false;

      function setProgress(value: number, label: string) {
        progressBar.setAttribute('value', String(value));
        progressBar.setAttribute('alias', `${value}%`);
        progressText.textContent = label;
      }

      function setFinishedState(
        label: 'Task stopped' | 'Task complete',
        variant: 'warning' | 'success',
        icon: string
      ) {
        entity.removeAttribute('await');
        entity.setAttribute('variant', variant);
        entity.setAttribute('icon', icon);
        cancelBtn.setAttribute('disabled', 'true');
        cancelBtn.textContent = label;
      }

      function resetToStart() {
        cancelled = false;
        chapterIndex = 0;
        entity.setAttribute('await', '');
        entity.setAttribute('icon', 'mgg/google-book-large-outline');
        cancelBtn.removeAttribute('disabled');
        cancelBtn.textContent = 'Stop';
        setProgress(0, 'Analyzing book');
      }

      function advance() {
        if (!isRunning || cancelled || !isInViewport) return;

        if (chapterIndex >= TOTAL_CHAPTERS) {
          setFinishedState('Task complete', 'success', 'mi/outline/done');
          isRunning = false;
          timeoutId = setTimeout(() => {
            resetToStart();
            tryStart();
          }, STOP_DELAY_MS);
          return;
        }

        const pct = Math.round(((chapterIndex + 1) / TOTAL_CHAPTERS) * 100);
        setProgress(pct, chapterLabels[chapterIndex]);
        chapterIndex++;
        const delay =
          Math.floor(Math.random() * (CHAPTER_DELAY_MAX_MS - CHAPTER_DELAY_MIN_MS + 1)) +
          CHAPTER_DELAY_MIN_MS;
        timeoutId = setTimeout(advance, delay);
      }

      function tryStart() {
        if (!contentWrapper || contentWrapper.hasAttribute('hidden')) return;
        if (!isInViewport) return;
        if (isRunning) return;
        isRunning = true;
        advance();
      }

      function stop() {
        cancelled = true;
        if (timeoutId) {
          clearTimeout(timeoutId);
          timeoutId = null;
        }
        setFinishedState('Task stopped', 'warning', 'mi/outline/block');
        setProgress(0, 'operation cancelled');
        isRunning = false;
        timeoutId = setTimeout(() => {
          resetToStart();
          tryStart();
        }, STOP_DELAY_MS);
      }

      cancelBtn.addEventListener('click', () => {
        if (!isRunning || cancelBtn.hasAttribute('disabled')) return;
        stop();
      });

      const visibilityObserver = new MutationObserver(() => tryStart());
      if (contentWrapper) {
        visibilityObserver.observe(contentWrapper, {
          attributes: true,
          attributeFilter: ['hidden'],
        });
      }

      const intersectionObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.target !== container) return;
            if (entry.isIntersecting) {
              isInViewport = true;
              if (!isRunning && !cancelled && chapterIndex < TOTAL_CHAPTERS) {
                tryStart();
              }
            } else {
              isInViewport = false;
              if (timeoutId) {
                clearTimeout(timeoutId);
                timeoutId = null;
              }
              isRunning = false;
            }
          });
        },
        { threshold: 0.1 }
      );

      intersectionObserver.observe(container);

      // Initial attempt once observers have had a chance to run
      requestAnimationFrame(() => {
        tryStart();
      });

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', () => {
          requestAnimationFrame(() => {
            tryStart();
          });
        });
      } else {
        requestAnimationFrame(() => {
          tryStart();
        });
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initBookAnalysisDemo);
    } else {
      initBookAnalysisDemo();
    }
  </script>
  <Usage>
    <UsageItem variant="do">
      Provide pause and stop controls for all AI processes that take time.
    </UsageItem>
    <UsageItem variant="dont">
      Force users to wait for AI processes to complete without interruption.
    </UsageItem>
    <UsageItem variant="do">
      Allow users to completely opt out of AI features in settings.
    </UsageItem>
    <UsageItem variant="dont">
      Make opt-out options hard to find or require multiple steps to disable AI.
    </UsageItem>
  </Usage>
</UseCase>
