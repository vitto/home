---
import UseCase from '../../../UseCase.astro';
import UseCaseInteractive from '../../../UseCaseInteractive.astro';
import Usage from '../../../Usage.astro';
import UsageItem from '../../../UsageItem.astro';
---

<UseCase
  title="Reversibility and Undo"
  description="Provide undo functionality for AI actions so users can return to previous states when needed."
>
  <UseCaseInteractive clsHeight={268} label="Undo functionality" toggle>
    <div class="grid gap-600 w-full">
      <mds-banner headline="Automatic email organization" icon="mi/outline/email" variant="primary">
        <mds-text typography="detail"
          >The AI has organized your emails into folders based on your preferences.</mds-text
        >
        <mds-list class="gap-200 mt-400">
          <mds-list-item icon="mi/outline/done">15 emails moved to <b>Work</b></mds-list-item>
          <mds-list-item icon="mi/outline/done">8 emails moved to <b>Personal</b></mds-list-item>
          <mds-list-item icon="mi/outline/done">3 emails moved to <b>Archive</b></mds-list-item>
        </mds-list>
        <mds-button slot="action" variant="dark" tone="weak">Undo organization</mds-button>
        <mds-button slot="action">Confirm changes</mds-button>
      </mds-banner>
    </div>
    <div class="grid gap-600 w-full">
      <mds-banner headline="Automatic email organization" icon="mi/outline/email" variant="primary">
        <mds-text typography="detail"
          >The AI has organized your emails into folders based on your preferences.</mds-text
        >
        <mds-list class="gap-200 mt-400">
          <mds-list-item icon="mi/outline/done">15 emails moved to <b>Work</b></mds-list-item>
          <mds-list-item icon="mi/outline/done">8 emails moved to <b>Personal</b></mds-list-item>
          <mds-list-item icon="mi/outline/done">3 emails moved to <b>Archive</b></mds-list-item>
        </mds-list>
      </mds-banner>
    </div>
  </UseCaseInteractive>
  <Usage>
    <UsageItem variant="do">
      Provide undo functionality for all AI actions that modify or delete content.
    </UsageItem>
    <UsageItem variant="dont">
      Perform irreversible actions without giving users a chance to undo them.
    </UsageItem>
    <UsageItem variant="do">
      Make undo options visible and easily accessible after AI actions.
    </UsageItem>
    <UsageItem variant="dont">Hide undo options or make them difficult to find or use.</UsageItem>
  </Usage>
</UseCase>
