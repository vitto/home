---
import UseCase from '../../../UseCase.astro';
import UseCaseInteractive from '../../../UseCaseInteractive.astro';
import Usage from '../../../Usage.astro';
import UsageItem from '../../../UsageItem.astro';
import MovieCard from '../../../MovieCard.astro';
import movies from '../../../../data/use-cases/movies.json';
---

<UseCase
  title="Design for Ambiguous or Multiple Outcomes"
  description="When the AI is uncertain or multiple interpretations are possible, present all reasonable options rather than forcing a single answer."
>
  <UseCaseInteractive clsHeight={112} label="Multiple outcomes" toggle>
    <div
      class="grid gap-600 w-full bg-tone-neutral-01 dark:bg-tone-neutral-09 text-tone-neutral dark:text-tone-neutral-01 rounded-lg grid-cols-full"
    >
      <div class="grid gap-600 p-600 pb-0">
        <div class="flex justify-between items-center gap-400">
          <mds-img class="w-full max-w-4000" src="/assets/streaming-logo.svg"></mds-img>
          <mds-avatar class="size-900" initials="vt"></mds-avatar>
        </div>
        <mds-hr class="bg-tone-neutral-03"></mds-hr>
        <mds-text typography="h5">Tips for the evening</mds-text>
      </div>
      <div class="flex gap-600 snap-x snap-mandator overflow-x-auto px-600 pb-600">
        {
          [...movies]
            .sort((a, b) => b.confidence - a.confidence)
            .map((movie) => (
              <MovieCard
                class="w-5600 snap-start scroll-m-600"
                title={movie.title}
                year={movie.year}
                genre={movie.genre}
                duration={movie.duration}
                rating={movie.rating}
                image={movie.image}
                confidence={movie.confidence}
                reasons={movie.reasons}
              />
            ))
        }
      </div>
    </div>
    <div class="grid gap-600 w-full bg-tone-neutral-01 text-tone-neutral rounded-lg grid-cols-full">
      <div class="grid gap-600 p-600 pb-0">
        <div class="flex justify-between items-center gap-400">
          <mds-img class="w-full max-w-4000" src="/assets/streaming-logo.svg"></mds-img>
          <mds-avatar class="size-900" initials="vt"></mds-avatar>
        </div>
        <mds-hr class="bg-tone-neutral-03"></mds-hr>
        <mds-text typography="h5">Tips for the evening</mds-text>
      </div>
      <div class="flex gap-600 snap-x snap-mandator overflow-x-auto px-600 pb-600">
        {
          [...movies]
            .sort((a, b) => b.confidence - a.confidence)
            .map((movie) => (
              <MovieCard
                class="w-5600 snap-start scroll-m-600"
                title={movie.title}
                year={movie.year}
                genre={movie.genre}
                duration={movie.duration}
                rating={movie.rating}
                image={movie.image}
              />
            ))
        }
      </div>
    </div>
  </UseCaseInteractive>
  <Usage>
    <UsageItem variant="do">
      Present multiple reasonable interpretations when the AI is uncertain.
    </UsageItem>
    <UsageItem variant="dont">
      Force a single answer when multiple outcomes are equally plausible.
    </UsageItem>
    <UsageItem variant="do">
      Show confidence levels for each possible outcome or interpretation.
    </UsageItem>
    <UsageItem variant="dont">Hide ambiguity by presenting only the most likely outcome.</UsageItem>
  </Usage>
</UseCase>
