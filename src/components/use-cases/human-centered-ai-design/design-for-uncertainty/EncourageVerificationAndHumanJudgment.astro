---
import UseCase from '../../../UseCase.astro';
import UseCaseInteractive from '../../../UseCaseInteractive.astro';
import Usage from '../../../Usage.astro';
import UsageItem from '../../../UsageItem.astro';
import CurriculumItem from '../../CurriculumItem.astro';
import cvData from '../../../../data/use-cases/cv.json';

const cvs = (
  cvData as Array<{
    id: number;
    name: string;
    role: string;
    seniority: string;
    location: string;
    jobMatchScore: number;
    aiConfidence: number;
    confidenceReasons: string[];
    riskFlags: string[];
  }>
).sort((a, b) => b.aiConfidence - a.aiConfidence);
---

<UseCase
  title="Encourage Verification and Human Judgment"
  description="When uncertainty is high, explicitly prompt users to verify outputs and use their judgment rather than blindly accepting AI recommendations."
>
  <UseCaseInteractive clsHeight={471} label="Verification prompts" multiple>
    <div class="grid gap-600 w-full max-w-8000">
      {cvs.slice(3, 4).map((cv) => <CurriculumItem highlight cv={cv} />)}
    </div>
    <div class="grid gap-600 w-full">
      <div class="grid gap-200">
        <mds-text typography="h6">CV list screening</mds-text>
        <mds-text typography="caption" class="text-tone-neutral-03">
          The AI suggests which CVs to shortlist, but always surfaces confidence, reasons, and risks
          so a human can double-check before deciding.
        </mds-text>
      </div>

      <mds-tab data-tab-filter>
        <mds-tab-item selected>All</mds-tab-item>
        <mds-tab-item>Needs review</mds-tab-item>
      </mds-tab>

      <div class="grid gap-600 tablet:grid-cols-2 auto-rows-min auto-cols-min" data-cv-list>
        {
          cvs.map((cv) => (
            <div data-cv-item data-needs-review={cv.aiConfidence < 0.9 ? 'true' : 'false'}>
              <CurriculumItem cv={cv} />
            </div>
          ))
        }
      </div>
    </div>
  </UseCaseInteractive>
  <Usage>
    <UsageItem variant="do">
      Prompt users to verify outputs when confidence is low or moderate.
    </UsageItem>
    <UsageItem variant="dont">
      Present uncertain outputs as if they're definitive and don't need verification.
    </UsageItem>
    <UsageItem variant="do">
      Provide easy ways to request human review or additional verification.
    </UsageItem>
    <UsageItem variant="dont">
      Make it difficult for users to question or override AI outputs.
    </UsageItem>
  </Usage>
</UseCase>

<script>
  function initCvTabFilter() {
    const tabFilter = document.querySelector('[data-tab-filter]');
    const list = document.querySelector('[data-cv-list]');
    if (!tabFilter || !list) return;

    const items = list.querySelectorAll('[data-cv-item]');
    const tabItems = tabFilter.querySelectorAll('mds-tab-item');
    if (!tabItems.length || !items.length) return;

    tabItems.forEach((tab, index) => {
      tab.addEventListener('click', () => {
        tabItems.forEach((t) => t.removeAttribute('selected'));
        tab.setAttribute('selected', '');
        const showNeedsReviewOnly = index === 1;
        items.forEach((el) => {
          const needsReview = el.getAttribute('data-needs-review') === 'true';
          (el as HTMLElement).hidden = showNeedsReviewOnly && !needsReview;
        });
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCvTabFilter);
  } else {
    initCvTabFilter();
  }
</script>
