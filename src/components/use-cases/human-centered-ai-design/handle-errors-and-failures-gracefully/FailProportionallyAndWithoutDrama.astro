---
import UseCase from '../../../UseCase.astro';
import UseCaseInteractive from '../../../UseCaseInteractive.astro';
import Usage from '../../../Usage.astro';
import UsageItem from '../../../UsageItem.astro';
import AIBalloon from '../../AIBalloon.astro';
import AIBalloonMessage from '../../AIBalloonMessage.astro';
import AIResponseMessage from '../../AIResponseMessage.astro';
import AIResponseFollowUpAction from '../../AIResponseFollowUpAction.astro';
import Markdown from '../../../Markdown.astro';
import AIResponseFollowUp from '../../AIResponseFollowUp.astro';
import HighlightBox from '../../HighlightBox.astro';
---

<UseCase
  title="Fail Proportionally and Without Drama"
  description="Match the tone and prominence of error messaging to the severity of the failure. Avoid overdramatic or alarming language for minor issues."
>
  <UseCaseInteractive clsHeight={160} label="Proportional failure messaging" toggle>
    <div class="grid gap-600 w-full max-w-9600">
      <AIBalloon>
        <AIBalloonMessage>
          I would like something for skin blemishes after the summer
        </AIBalloonMessage>
      </AIBalloon>
      <AIResponseMessage>
        <HighlightBox label="progressive failure" variant="success" class="relative grid gap-600">
          <Markdown
            typography="detail"
            content={`
  I may need a little more detail to recommend the best treatment. Could you tell me your skin type or any sensitivities?
          `}
          />
        </HighlightBox>
      </AIResponseMessage>
    </div>
    <div class="grid gap-600 w-full max-w-9600">
      <AIBalloon>
        <AIBalloonMessage>
          I would like something for skin blemishes after the summer
        </AIBalloonMessage>
      </AIBalloon>
      <AIResponseMessage>
        <HighlightBox label="disproportionate error" variant="error" class="relative grid gap-600">
          <Markdown
            typography="detail"
            content={`
I couldn't determine an appropriate treatment for your request.

Skin blemishes can be caused by multiple factors (hormonal, UV exposure, skin conditions) and require a thorough evaluation.

Try to:

- Consult a dermatologist before proceeding
- Avoid any unsupervised treatment
- Provide detailed information (skin type, age, medical history, medications currently being used)
          `}
          />
        </HighlightBox>
      </AIResponseMessage>
    </div>
  </UseCaseInteractive>
  <Usage>
    <UsageItem variant="do">
      Match error prominence and tone to severity (minor = subtle, serious = prominent).
    </UsageItem>
    <UsageItem variant="dont">
      Use alarming or overdramatic language for minor or recoverable failures.
    </UsageItem>
    <UsageItem variant="do">
      Use calm, factual language that explains the issue without exaggerating.
    </UsageItem>
    <UsageItem variant="dont">
      Treat every failure as critical; reserve strong messaging for truly serious issues.
    </UsageItem>
  </Usage>
</UseCase>
