---
import UseCase from '../../../UseCase.astro';
import UseCaseInteractive from '../../../UseCaseInteractive.astro';
import Usage from '../../../Usage.astro';
import UsageItem from '../../../UsageItem.astro';
import articleSourcesData from '../../../../data/use-cases/article-sources.json';
import AILink from '../../AILink.astro';
---

<UseCase
  title="Design for Recovery, Not Just Notification"
  description="Every error state should offer a path to recover—retry, alternative action, or safe fallback—not just inform the user that something failed."
>
  <UseCaseInteractive clsHeight={304} label="Recovery options" toggle>
    <div class="grid gap-600 w-full max-w-9600">
      <div class="grid gap-200 grid-cols-full">
        <mds-text typography="label">Source</mds-text>
        {
          articleSourcesData
            .slice(0, 1)
            .map(
              (articleSource: {
                source: string;
                title: string;
                description: string;
                image: string;
              }) => (
                <mds-entity class="w-full" src={articleSource.image} variant="blue" tone="weak">
                  <mds-text typography="h6">{articleSource.title}</mds-text>
                  <mds-badge variant="blue" tone="weak" slot="detail" class="mr-150">
                    article
                  </mds-badge>
                  <mds-text typography="caption" slot="detail">
                    {articleSource.description}
                  </mds-text>
                </mds-entity>
              )
            )
        }
      </div>
      <div class="grid gap-200">
        <mds-text typography="label">generated article summary</mds-text>
        <mds-banner
          data-error-banner
          variant="error"
          headline="Summary generation failed"
          icon="mi/outline/warning-amber"
        >
          <mds-text typography="detail">
            The summary generation failed due to a timeout request.
          </mds-text>
          <mds-button
            data-retry-button
            variant="error"
            tone="weak"
            icon="mi/outline/replay"
            title="Retry">Retry</mds-button
          >
        </mds-banner>
        <div data-summary-container class="hidden gap-200">
          <div class="grid gap-400 p-600 rounded-lg bg-tone-neutral-10">
            <mds-text typography="h4">When global crises shape local decisions</mds-text>
            <mds-text typography="detail">
              Drawing on IMF, World Bank, OECD, WEF and Financial Times analyses of the world
              economic crisis, this AI-generated brief highlights how macroeconomic shocks,
              inflation and financial instability can influence everyday choices — while stressing
              that the final responsibility for decisions remains with the human.
            </mds-text>
          </div>
          <div class="flex gap-200 justify-between flex-wrap">
            <div class="flex gap-200 flex-wrap">
              <mds-button variant="error" tone="weak" icon="mi/outline/delete" title="Delete"
              ></mds-button>
            </div>
            <div class="flex gap-200 flex-wrap">
              <mds-button variant="dark" tone="quiet" icon="mi/outline/replay" title="Regenerate"
              ></mds-button>
              <mds-button variant="dark" tone="quiet" icon="mi/outline/edit" title="Edit"
              ></mds-button>
              <mds-button variant="success" icon="mi/outline/publish" icon-position="right"
                >Publish</mds-button
              >
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="grid gap-600 w-full max-w-9600">
      <div class="grid gap-200 grid-cols-full">
        <mds-text typography="label">Source</mds-text>
        {
          articleSourcesData
            .slice(0, 1)
            .map(
              (articleSource: {
                source: string;
                title: string;
                description: string;
                image: string;
              }) => (
                <mds-entity class="w-full" src={articleSource.image} variant="blue" tone="weak">
                  <mds-text typography="h6">{articleSource.title}</mds-text>
                  <mds-badge variant="blue" tone="weak" slot="detail" class="mr-150">
                    article
                  </mds-badge>
                  <mds-text typography="caption" slot="detail">
                    {articleSource.description}
                  </mds-text>
                </mds-entity>
              )
            )
        }
      </div>
      <div class="grid gap-200">
        <mds-text typography="label">generated article summary</mds-text>
        <mds-banner
          variant="error"
          headline="Summary generation failed"
          icon="mi/outline/warning-amber"
        >
          <mds-text typography="detail">
            The summary generation failed due to a timeout request.
          </mds-text>
        </mds-banner>
      </div>
    </div>
  </UseCaseInteractive>
  <script>
    function initRecoveryDemo() {
      const scope = (window as any).getUseCaseScope?.('design-for-recovery-not-just-notification');
      if (!scope) return;

      const { container } = scope;
      const retryButton = container.querySelector('[data-retry-button]');
      const errorBanner = container.querySelector('[data-error-banner]');
      const summaryContainer = container.querySelector('[data-summary-container]');

      if (!retryButton || !errorBanner || !summaryContainer) return;

      let showSummaryTimer: ReturnType<typeof setTimeout> | null = null;
      let rollbackTimer: ReturnType<typeof setTimeout> | null = null;

      const rollback = () => {
        retryButton.removeAttribute('await');
        retryButton.setAttribute('icon', 'mi/outline/replay');
        retryButton.textContent = 'Retry';

        errorBanner.classList.remove('hidden');
        summaryContainer.classList.remove('grid');
        summaryContainer.classList.add('hidden');
      };

      retryButton.addEventListener('click', () => {
        if (showSummaryTimer) clearTimeout(showSummaryTimer);
        if (rollbackTimer) clearTimeout(rollbackTimer);

        retryButton.setAttribute('await', '');
        retryButton.removeAttribute('icon');
        retryButton.textContent = 'Regenerating...';

        showSummaryTimer = setTimeout(() => {
          errorBanner.classList.add('hidden');
          summaryContainer.classList.remove('hidden');
          summaryContainer.classList.add('grid');

          rollbackTimer = setTimeout(() => {
            rollback();
          }, 3000);
        }, 2000);
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initRecoveryDemo);
    } else {
      initRecoveryDemo();
    }
  </script>
  <Usage>
    <UsageItem variant="do">
      Provide at least one clear recovery path for every error (retry, alternative, or safe
      fallback).
    </UsageItem>
    <UsageItem variant="dont">
      Show only an error message with no way to recover or continue.
    </UsageItem>
    <UsageItem variant="do">
      Match recovery options to the type of failure (e.g. retry for timeouts, different input for
      invalid data).
    </UsageItem>
    <UsageItem variant="dont">
      Make recovery actions hard to find or require multiple steps when one would suffice.
    </UsageItem>
  </Usage>
</UseCase>
