---
/**
 * AIBalloon Component
 *
 * Balloon-style container for User messages in use cases.
 *
 * Props:
 * @param {string} class - Additional CSS classes
 */
interface Props {
  class?: string;
  [key: string]: unknown;
}

const { class: className = '', ...attrs } = Astro.props;
---

<div class={`grid gap-400 ${className}`} data-ai-balloon {...attrs}>
  <slot />
</div>
