---
/**
 * AIInput Component
 *
 * Input message bubble for user messages in AI use cases.
 *
 * Props:
 * @param {string} class - Additional CSS classes
 */
interface Props {
  class?: string;
  value?: string;
  type?: 'text' | 'textarea';
  [key: string]: unknown;
}

const { class: className = '', value = '', type = 'text', ...attrs } = Astro.props;
---

<mds-input
  class={`rounded-full ${className}`}
  type={type}
  variant="ai"
  placeholder="Ask something"
  value={value}
  data-ai-input
  {...attrs}></mds-input>
